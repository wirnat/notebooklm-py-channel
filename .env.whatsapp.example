# =============================================================================
# NOTEBOOKLM <-> WHATSAPP BRIDGE (DOCKER)
# Copy file ini ke .env.whatsapp lalu sesuaikan nilainya.
# =============================================================================

# Wajib: secret yang sama dipakai GoWA (sender webhook) dan bridge (validator HMAC).
WA_WEBHOOK_SECRET=ganti-dengan-secret-random-panjang
GOWA_WEBHOOK_URL=http://host.docker.internal:8787/webhook/whatsapp

# Port host
GOWA_UI_PORT=8781
WA_BRIDGE_PORT=8787

# Path auth NotebookLM di host. Isi dengan path absolut agar stabil di Docker Compose.
# Contoh macOS: /Users/iturban/.notebooklm
NOTEBOOKLM_HOME_HOST=/Users/iturban/.notebooklm

# Opsional: jika tidak mau mount file auth, bisa isi JSON auth inline.
# NOTEBOOKLM_AUTH_JSON={"cookies":[...]}

# Opsional: notebook global default untuk command WA /nb ask
NOTEBOOKLM_WA_GLOBAL_NOTEBOOK_ID=

# Opsional: admin whitelist, pisahkan dengan koma
# Contoh: NOTEBOOKLM_WA_ADMINS=62812xxxx,62813yyyy
NOTEBOOKLM_WA_ADMINS=

# Opsional bridge behavior
NOTEBOOKLM_WA_ALLOW_GROUPS=false
NOTEBOOKLM_WA_MAX_REPLY_CHARS=3000

# Opsional GoWA behavior
GOWA_APP_DEBUG=false
GOWA_BASIC_AUTH=
GOWA_WHATSAPP_AUTO_MARK_READ=false
GOWA_WHATSAPP_AUTO_DOWNLOAD_MEDIA=true
GOWA_WHATSAPP_ACCOUNT_VALIDATION=true
